# Dependencies
node_modules/

# Build outputs
dist/
packages/*/dist/
storybook-static/

# But SHIP the built tokens + icons + react components so consumers can clone-and-go without rebuilding
!packages/mds-tokens/dist
!packages/mds-tokens/dist/**
!packages/mds-icons/dist
!packages/mds-icons/dist/**
!packages/mds-components/dist
!packages/mds-components/dist/**

# Generated source
packages/mds-icons/src/generated/

# Local-only docs / scratch / audits (kept out of GitHub)
docs/
.audit-2026-04-24/
audit-findings-2026-04-24/

# Smoke-test / agent transients
.playwright-mcp/

# OS / editor
.DS_Store
*.log

# Obsidian per-user UI state (pane sizes, last-opened tabs) — churns on every
# editor interaction. Shared editor config (app.json, appearance.json,
# graph.json, core-plugins.json) stays tracked.
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json

# Secrets — keep out of the repo at every level
.env
.env.local
*.env
