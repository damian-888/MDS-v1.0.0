{
  "name": "mds",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter @mds/tokens build && pnpm -r --filter @mds/icons build && pnpm -r --filter @mds/react build && pnpm -r --filter @mds/agents build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "storybook": "pnpm --filter @mds/react storybook",
    "changeset": "changeset",
    "release": "pnpm -r build && changeset publish",
    "clean": "pnpm -r exec rm -rf dist && rm -rf node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.5.2",
    "typescript": "^5.7.3"
  }
}
