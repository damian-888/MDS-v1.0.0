{
  "name": "@mds/components",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./MDSButton": {
      "types": "./dist/MDSButton/index.d.ts",
      "import": "./dist/MDSButton/index.js"
    },
    "./MDSIcon": {
      "types": "./dist/MDSIcon/index.d.ts",
      "import": "./dist/MDSIcon/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'no lint configured for @mds/react yet' && exit 0",
    "typecheck": "tsc --noEmit",
    "storybook": "echo '@mds/react storybook lives in @mds/guidelines (future package)' && exit 0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@mds/tokens": "workspace:*"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@mds/icons": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  }
}
