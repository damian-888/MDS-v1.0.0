{
  "name": "@mds/icons",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "sync": "node --env-file=.env scripts/sync-from-figma.mjs",
    "generate": "node scripts/build-icons.mjs",
    "build": "pnpm generate && vite build",
    "dev": "node scripts/build-icons.mjs --watch",
    "clean": "rm -rf dist src/generated",
    "test": "echo 'no icons tests' && exit 0",
    "lint": "eslint . --ext .js,.mjs,.ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.0",
    "chokidar": "^4.0.0",
    "glob": "^11.0.0",
    "react": "^18.3.0",
    "svgo": "^3.3.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0"
  }
}
